  {
    "id": 31,
    "category": "Grammaire",
    "title": "La négation « ne...pas »",
    "content": "Se forme avec « pa » placé avant le verbe : Mwen pa vle (Je ne veux pas).",
    "audioPath": "assets/audios/grammaire/negation_pa.mp3",
    "order": 1
  },
  {
    "id": 32,
    "category": "Grammaire",
    "title": "Les pronoms personnels",
    "content": "Mwen (je), ou (tu), li (il/elle), nou (nous/vous), yo (ils/elles).",
    "audioPath": "assets/audios/grammaire/pronoms_personnels.mp3",
    "order": 2
  },
  {
    "id": 33,
    "category": "Grammaire",
    "title": "Le futur proche",
    "content": "Se marque avec « ap » ou « va » : Mwen ap manje (Je vais manger).",
    "audioPath": "assets/audios/grammaire/futur_proche.mp3",
    "order": 3
  },
  {
    "id": 34,
    "category": "Grammaire",
    "title": "Le passé composé",
    "content": "Se marque avec « te » : Mwen te manje (J'ai mangé).",
    "audioPath": "assets/audios/grammaire/passe_te.mp3",
    "order": 4
  },
  {
    "id": 35,
    "category": "Grammaire",
    "title": "Le pluriel",
    "content": "Se forme en ajoutant « yo » après le nom : Liv yo (Les livres).",
    "audioPath": "assets/audios/grammaire/pluriel_yo.mp3",
    "order": 5
  },
  {
    "id": 36,
    "category": "Grammaire",
    "title": "Le possessif",
    "content": "Le possesseur se place après le nom : Kay mwen (Ma maison).",
    "audioPath": "assets/audios/grammaire/possessif.mp3",
    "order": 6
  },
  {
    "id": 37,
    "category": "Grammaire",
    "title": "La question avec « est-ce que »",
    "content": "La phrase commence par « Èske » : Èske ou vini ? (Est-ce que tu viens ?).",
    "audioPath": "assets/audios/grammaire/question_eske.mp3",
    "order": 7
  },
  {
    "id": 38,
    "category": "Grammaire",
    "title": "L'article défini",
    "content": "Se place après le nom, sous la forme « la » ou « a » : Kay la (La maison).",
    "audioPath": "assets/audios/grammaire/article_defini.mp3",
    "order": 8
  },
  {
    "id": 39,
    "category": "Grammaire",
    "title": "Le verbe « être » sous-entendu",
